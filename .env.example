# Copy to .env for running services directly on the host (outside compose).
# Inside docker-compose these are set per-service in docker-compose.yml.

APP_ENV=development
APP_LOG_LEVEL=info
APP_HTTP_PORT=8080

# MySQL (host defaults assume the compose MySQL published on 3307)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=moderate
MYSQL_PASSWORD=moderate
MYSQL_DATABASE=moderate

# Redis (compose Redis published on 6380)
REDIS_ADDR=127.0.0.1:6380
REDIS_PASSWORD=
REDIS_DB=0

# Kafka (compose broker host listener on 29092)
KAFKA_BROKERS=127.0.0.1:29092
KAFKA_REVIEW_TOPIC=post-review-topic
KAFKA_RESULT_TOPIC=review-result-topic
KAFKA_DLQ_TOPIC=post-review-dlq
KAFKA_CONSUMER_GROUP=review-service
KAFKA_PARTITIONS=3

# gRPC
GRPC_USER_LISTEN=:9090
GRPC_USER_ADDR=127.0.0.1:9090
